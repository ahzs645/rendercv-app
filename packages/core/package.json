{
  "name": "@rendercv/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./analytics/events": {
      "types": "./dist/analytics/events.d.ts",
      "default": "./dist/analytics/events.js"
    },
    "./assets/url": {
      "types": "./dist/assets/url.d.ts",
      "default": "./dist/assets/url.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --config vitest.config.ts"
  },
  "dependencies": {
    "@rendercv/contracts": "workspace:*",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
