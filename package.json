{
  "name": "rendercv",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "pnpm --filter @rendercv/web dev",
    "dev:web": "pnpm --filter @rendercv/web dev",
    "dev:api": "pnpm --filter @rendercv/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @rendercv/web build",
    "build:api": "pnpm --filter @rendercv/api build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "preview": "pnpm --filter @rendercv/web preview"
  }
}
